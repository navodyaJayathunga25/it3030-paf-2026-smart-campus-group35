    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status is 200\", () => {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Registration successful\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.success).to.be.true;\r",
                  "    pm.expect(json.message).to.include(\"Registration successful\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Email verification message present\", () => {\r",
                  "    const json = pm.response.json();\r",
                  "    pm.expect(json.message).to.include(\"Check your email\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"name\": \"John Doe\",\r\n    \"email\": \"john@example.com\",\r\n    \"password\": \"password123\",\r\n    \"role\": \"USER\",\r\n    \"department\": \"Computer Science\"\r\n}",
